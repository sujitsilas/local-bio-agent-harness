# raw dropped notebooks/scripts (can be huge) — the EXTRACTED examples/ *are* committed
examples_raw/*
!examples_raw/.gitkeep

# data + large notebooks
*.h5ad
*.ipynb
macrophages_test/

# python / tooling cruft
__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store
.opencode/

# old-harness runtime
.runs/
*.sqlite
