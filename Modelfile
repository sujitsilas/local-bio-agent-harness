# Tuned coding model for opencode. Build with:  ollama create qwen3.6-coding -f Modelfile
#
# Use the GGUF q8_0 weights, NOT mxfp8: Ollama's MLX engine (which serves mxfp8/nvfp4)
# does not stream in Ollama 0.24, so streaming clients like opencode hang with 0 tokens.
# q8_0 runs on the llama.cpp engine (streams) and is near-lossless 8-bit — the quality
# equivalent of mxfp8 without the streaming break. Ollama's fixed context (num_ctx) still
# bounds the KV cache, so no Metal OOM on long sessions.
FROM qwen3.6:35b-a3b-q8_0

# fixed context -> bounded KV cache, no Metal OOM (comments must be on their own line)
PARAMETER num_ctx 16384

# the Ollama default presence_penalty (1.5) penalizes correct code repetition
PARAMETER presence_penalty 0

PARAMETER temperature 0.7
